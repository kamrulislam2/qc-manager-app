{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QC App",
  "version": "3.5.0",
  "identifier": "com.qc.manager",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QC App",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "app"],
    "createUpdaterArtifacts": true,
    "publisher": "Kamrul Islam, IT Officer, B&F Corporate",
    "copyright": "Developed by Kamrul Islam, IT Officer, B&F Corporate",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/kamrulislam2/qc-manager-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCM0VDOTIxOTA2NjlFNTQKUldSVW5tYVFJY2srVzdXYlBRTTFoTXl5Z0VscTNRQyt0SDRmUzJFTU14U2FIaEFMMldHVEF1QWIK"
    }
  }
}
